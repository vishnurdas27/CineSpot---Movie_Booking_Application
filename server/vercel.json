{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["dist/**"],
        "maxDuration": 30
      }
    }
  ],
  "routes": [
    {
      "src": "/api/inngest",
      "dest": "server.js",
      "methods": ["GET", "POST", "PUT"]
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}